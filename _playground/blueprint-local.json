{
    "$schema": "https://playground.wordpress.net/blueprint-schema.json",
    "landingPage": "/wp-admin/post.php?post=4&action=edit",
    "login": true,
    "features": {
        "networking": true
    },
    "steps": [
        {
            "step": "updateUserMeta",
            "meta": {
                "admin_color": "modern",
                "show_welcome_panel": 0
            },
            "userId": 1
        },
        {
            "step": "setSiteOptions",
            "options": {
                "blogname": "Visual Blueprint Builder | Local Dev 🧑‍💻"
            }
        }
    ]
}
